# Public canonical origin used for metadata and social cards. Set this to the
# final HTTPS production origin in Vercel.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional server-only credential for live GPT-5.6 generation. When empty,
# Encore returns visibly labeled deterministic demo fixtures that match the
# production response schemas. Never expose this as NEXT_PUBLIC_*.
OPENAI_API_KEY=
