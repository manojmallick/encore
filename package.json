{
  "name": "encore",
  "version": "0.1.0",
  "private": true,
  "description": "A song-to-publish practice planner for independent cover artists.",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "sigmap",
    "map:refresh": "sigmap",
    "map:report": "sigmap --report --json",
    "map:watch": "sigmap daemon start",
    "map:setup": "sigmap --setup"
  },
  "dependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vercel/config": "^0.5.5",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "sigmap": "^8.18.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10"
    }
  }
}
